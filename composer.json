{
    "name": "thefayzullin/companies-test",
    "description": "WordPress test task: Companies Directory",
    "type": "project",
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1"
    },
    "scripts": {
        "lint:php": "phpcs --standard=WordPress wp-content/plugins/companies-directory wp-content/themes/companies-child"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}